generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  HOMEOWNER
  AGENT
  ADMIN
}

enum UserDataOrigin {
  PRODUCTION
  PREVIEW
  SEED
  TEST
}

enum PreferredContactMethod {
  EMAIL
  PHONE
}

enum VerificationStatus {
  UNVERIFIED
  PENDING
  VERIFIED
  REJECTED
}

enum AgentProfileStatus {
  DRAFT
  PUBLISHED
}

enum AgentFeePreference {
  FIXED_FEE
  PERCENTAGE
  HYBRID
  CASE_BY_CASE
}

enum AgentTransactionBand {
  UNDER_250K
  FROM_250K_TO_500K
  FROM_500K_TO_1M
  FROM_1M_TO_2M
  OVER_2M
}

enum CollaborationPreference {
  JV_OR_REFERRALS
  REFERRALS_ONLY
  SELECTIVE
  NOT_OPEN
}

enum PropertyType {
  FLAT
  TERRACED
  SEMI_DETACHED
  DETACHED
  BUNGALOW
  OTHER
}

enum TargetTimeline {
  ASAP
  FOUR_TO_EIGHT_WEEKS
  FLEXIBLE
}

enum InstructionStatus {
  DRAFT
  LIVE
  CLOSED
  SHORTLIST
  AWARDED
}

enum FeeModel {
  FIXED
  PERCENT
  HYBRID
  SUCCESS_BANDS
}

enum CurrencyCode {
  GBP
}

enum ServiceInclusion {
  PROFESSIONAL_PHOTOGRAPHY
  FLOORPLAN
  PORTAL_LISTINGS
  HOSTED_VIEWINGS
  ACCOMPANIED_VIEWINGS
  SALES_PROGRESSION_SUPPORT
  EPC_ASSISTANCE
}

enum ProposalStatus {
  SUBMITTED
  SHORTLISTED
  REJECTED
  ACCEPTED
}

enum ThreadStatus {
  LOCKED
  OPEN
}

model User {
  id               String           @id @default(cuid())
  role             UserRole?
  dataOrigin       UserDataOrigin   @default(PRODUCTION)
  name             String?
  email            String           @unique
  emailVerified    DateTime?
  passwordHash     String?
  passwordSetAt    DateTime?
  image            String?
  createdAt        DateTime         @default(now())
  homeownerProfile HomeownerProfile?
  agentProfile     AgentProfile?
  properties       Property[]
  agentProposals   Proposal[]       @relation("AgentProposals")
  messages         Message[]
  homeownerThreads MessageThread[]  @relation("ThreadHomeowner")
  agentThreads     MessageThread[]  @relation("ThreadAgent")
  idempotencyKeys  IdempotencyKey[]
  accounts         Account[]
  sessions         Session[]
  productEventsAsActor   ProductEvent[] @relation("ProductEventActor")
  productEventsAsSubject ProductEvent[] @relation("ProductEventSubject")

  @@index([dataOrigin])
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?  @db.Text
  access_token      String?  @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?  @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
  @@index([userId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([sessionToken])
  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model HomeownerProfile {
  userId                 String                 @id
  phone                  String?
  preferredContactMethod PreferredContactMethod @default(EMAIL)
  createdAt              DateTime               @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AgentProfile {
  userId              String             @id
  agencyName          String?
  jobTitle            String?
  phone               String?
  workEmail           String?
  workEmailVerifiedAt DateTime?
  workEmailVerificationCodeHash String?
  workEmailVerificationCodeExpiresAt DateTime?
  workEmailVerificationCodeSentAt DateTime?
  workEmailVerificationAttemptCount Int @default(0)
  workEmailVerificationLockedUntil DateTime?
  bio                 String?
  yearsExperience     Int?
  serviceAreas        String[]           @default([])
  specialties         String[]           @default([])
  achievements        String[]           @default([])
  languages           String[]           @default([])
  feePreference       AgentFeePreference?
  transactionBand     AgentTransactionBand?
  collaborationPreference CollaborationPreference?
  profileSlug         String?            @unique
  profileStatus       AgentProfileStatus @default(DRAFT)
  profileCompleteness Int                @default(0)
  verificationStatus  VerificationStatus @default(UNVERIFIED)
  ratingAggregate     Float?
  responseTimeMinutes Int?
  createdAt           DateTime           @default(now())
  onboardingCompletedAt DateTime?
  publishedAt         DateTime?
  updatedAt           DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([profileStatus, verificationStatus])
  @@index([verificationStatus])
}

model Property {
  id               String       @id @default(cuid())
  ownerId          String
  addressLine1     String
  city             String
  postcode         String
  propertyType     PropertyType
  bedrooms         Int
  bathrooms        Int?
  shortDescription String
  photos           String[]
  createdAt        DateTime     @default(now())

  owner        User          @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  instructions Instruction[]

  @@index([ownerId])
  @@index([postcode])
}

model Instruction {
  id               String            @id @default(cuid())
  propertyId       String
  sellerGoals      String
  mustHaves        String[]          @default([])
  targetTimeline   TargetTimeline
  bidWindowStartAt DateTime
  bidWindowEndAt   DateTime
  status           InstructionStatus @default(DRAFT)
  createdAt        DateTime          @default(now())

  property  Property       @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  proposals Proposal[]
  threads   MessageThread[]

  @@index([status, bidWindowEndAt])
  @@index([propertyId])
}

model Proposal {
  id                String             @id @default(cuid())
  instructionId     String
  agentId           String
  feeModel          FeeModel
  feeValue          Decimal            @db.Decimal(10, 2)
  currency          CurrencyCode       @default(GBP)
  inclusions        ServiceInclusion[]
  marketingPlan     String
  timelineDays      Int
  cancellationTerms String
  status            ProposalStatus     @default(SUBMITTED)
  createdAt         DateTime           @default(now())

  instruction Instruction @relation(fields: [instructionId], references: [id], onDelete: Cascade)
  agent       User        @relation("AgentProposals", fields: [agentId], references: [id], onDelete: Cascade)

  @@unique([instructionId, agentId])
  @@index([instructionId, status])
  @@index([agentId])
}

model MessageThread {
  id            String       @id @default(cuid())
  instructionId String
  homeownerId   String
  agentId       String
  status        ThreadStatus @default(LOCKED)
  createdAt     DateTime     @default(now())

  instruction Instruction @relation(fields: [instructionId], references: [id], onDelete: Cascade)
  homeowner   User        @relation("ThreadHomeowner", fields: [homeownerId], references: [id], onDelete: Cascade)
  agent       User        @relation("ThreadAgent", fields: [agentId], references: [id], onDelete: Cascade)
  messages    Message[]

  @@unique([instructionId, homeownerId, agentId])
  @@index([status])
}

model Message {
  id        String   @id @default(cuid())
  threadId  String
  senderId  String
  body      String
  createdAt DateTime @default(now())

  thread MessageThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  sender User          @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([threadId, createdAt])
}

model IdempotencyKey {
  id             String   @id @default(cuid())
  actorId        String
  route          String
  key            String
  requestHash    String
  responseStatus Int
  responseBody   Json
  createdAt      DateTime @default(now())
  expiresAt      DateTime

  actor User @relation(fields: [actorId], references: [id], onDelete: Cascade)

  @@unique([actorId, route, key])
  @@index([route, createdAt])
  @@index([expiresAt])
}

model ProductEvent {
  id            String   @id @default(cuid())
  eventName     String
  actorRole     UserRole?
  actorId       String?
  subjectUserId String?
  source        String?
  metadata      Json?
  createdAt     DateTime @default(now())

  actor       User? @relation("ProductEventActor", fields: [actorId], references: [id], onDelete: SetNull)
  subjectUser User? @relation("ProductEventSubject", fields: [subjectUserId], references: [id], onDelete: SetNull)

  @@index([eventName, createdAt])
  @@index([subjectUserId, eventName, createdAt])
  @@index([actorId, eventName, createdAt])
}

model SupportInquiry {
  id        String   @id @default(cuid())
  name      String
  email     String
  role      String?
  category  String
  message   String
  pagePath  String?
  source    String?
  status    String   @default("OPEN")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, createdAt])
  @@index([category, createdAt])
}
