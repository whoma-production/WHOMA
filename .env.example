# App
NEXT_PUBLIC_APP_NAME=WHOMA
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_ANALYTICS_ENABLED=false
NEXT_PUBLIC_COMPANY_LEGAL_NAME=WHOMA
NEXT_PUBLIC_LOGO_SUBTITLE=Identity and reputation infrastructure for estate agents
NEXT_PUBLIC_SUPPORT_EMAIL=support@whoma.co.uk
NEXT_PUBLIC_SUPPORT_RESPONSE_WINDOW=3 business days
NEXT_PUBLIC_SUPPORT_COVERAGE=Support is coordinated through a monitored email route during the pilot.
NEXT_PUBLIC_BETA_STATUS_LABEL=Phase 1 controlled pilot
NEXT_PUBLIC_PILOT_SUMMARY=WHOMA is validating verified estate-agent identity, agent-owned reputation, and structured collaboration before any broader public launch.
NEXT_PUBLIC_OPERATING_REGION=United Kingdom

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/whoma_mvp?schema=public

# Auth (Supabase)
AUTH_SECRET=replace-with-strong-random-value
AUTH_URL=http://localhost:3000
NEXT_PUBLIC_AUTH_CALLBACK_ORIGIN=http://localhost:3000
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_GOOGLE_OAUTH_ENABLED=true
SUPABASE_EMAIL_AUTH_ENABLED=true
RESEND_API_KEY=
RESEND_FROM_EMAIL=WHOMA <verify@updates.whoma.co.uk>
WORK_EMAIL_VERIFICATION_RESEND_COOLDOWN_SECONDS=60
WORK_EMAIL_VERIFICATION_MAX_ATTEMPTS=5
WORK_EMAIL_VERIFICATION_LOCK_MINUTES=15

# Storage (S3-compatible)
S3_ENDPOINT=https://example.r2.cloudflarestorage.com
S3_REGION=auto
S3_BUCKET=whoma-mvp
S3_ACCESS_KEY_ID=replace-me
S3_SECRET_ACCESS_KEY=replace-me

# Feature flags / product rules
CHAT_UNLOCK_RULE=SHORTLIST_OR_AWARD
BID_WINDOW_MIN_HOURS=24
BID_WINDOW_MAX_HOURS=48

# Shared API safety infra (Upstash Redis)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Resume AI intake
OPENAI_API_KEY=
RESUME_OCR_ENDPOINT=
RESUME_OCR_API_KEY=
RESUME_OCR_STUB_TEXT=
ENABLE_RESUME_AI_PREFILL=true
RESUME_PREFILL_MODE=llm_only
ENABLE_RESUME_OCR_FALLBACK=false
RESUME_LLM_PROVIDER=openai
RESUME_LLM_MODEL=gpt-5.4
RESUME_CLEANUP_MODEL=gpt-5.4-mini
RESUME_LLM_TIMEOUT_MS=8000
RESUME_MIN_CONFIDENCE=0.70
RESUME_AI_SHADOW_MODE=false
RESUME_UPLOAD_LIMIT_PER_HOUR=6
RESUME_MAX_FILE_MB=4
